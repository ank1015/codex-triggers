{
  "name": "codexmaxxing",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @codexmaxxing/trigger dev",
    "desktop": "pnpm --filter @codexmaxxing/desktop dev",
    "desktop:signed": "pnpm --filter @codexmaxxing/desktop dev",
    "desktop:start": "pnpm --filter @codexmaxxing/desktop start",
    "desktop:smoke": "pnpm --filter @codexmaxxing/desktop smoke",
    "funnel": "pnpm --filter @codexmaxxing/trigger funnel",
    "funnel:reset": "pnpm --filter @codexmaxxing/trigger funnel:reset",
    "funnel:status": "pnpm --filter @codexmaxxing/trigger funnel:status",
    "start": "pnpm --filter @codexmaxxing/trigger start",
    "test": "pnpm -r test",
    "test:codex-app-server-live": "pnpm --filter @codexmaxxing/trigger test:codex-app-server-live",
    "test:codex-app-live": "pnpm --filter @codexmaxxing/trigger test:codex-app-live",
    "test:codex-live": "pnpm --filter @codexmaxxing/trigger test:codex-live",
    "typecheck": "pnpm -r typecheck"
  }
}
